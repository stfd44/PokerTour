rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isAuth() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function allowedNonCreatorFieldsChanged() {
      // Checks that the only fields being modified are 'games' and/or 'registrations'.
      // All other fields must remain identical.
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['games', 'registrations']);
    }

    // --- Rules ---
    match /teams/{teamId} {
      allow create: if isAuth();
      allow read: if isAuth();
      allow update: if isAuth(); // Any authenticated user can update (e.g., join/leave)
      allow delete: if isUser(resource.data.creatorId);
    }

    match /tournaments/{tournamentId} {
      allow create: if isAuth();
      allow read: if true; // Anyone can read tournament details

      allow update: if isAuth() && (
        // Rule 1: The creator can always update the tournament.
        isUser(resource.data.creatorId) ||
        // Rule 2: Any authenticated user can modify ONLY the 'games' and/or 'registrations' array.
        // This keeps tournament metadata protected while allowing synced game actions and registrations.
        allowedNonCreatorFieldsChanged()
      );
      
      allow delete: if isUser(resource.data.creatorId);
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create, update: if isUser(userId);

      match /devices/{deviceId} {
        allow read, create, update, delete: if isUser(userId);
      }
    }
  }
}
